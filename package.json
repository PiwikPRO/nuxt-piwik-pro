{
  "name": "@piwikpro/nuxt-piwik-pro",
  "private": false,
  "version": "1.5.0",
  "description": "Dedicated Piwik PRO library that helps with implementing Piwik PRO Tag Manager and the Piwik PRO tracking client in Nuxt.js applications.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./composables": "./dist/composables/index.js"
  },
  "typesVersions": {
    "*": {
      "composables": [
        "dist/composables/index.d.ts"
      ]
    }
  },
  "source": "src/index.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "version": "node scripts/bakeInVersion.js && auto-changelog -p && git add CHANGELOG.md src/version.ts",
    "build": "node scripts/bakeInVersion.js && tsc -b",
    "build:docs": "typedoc && concat-md --decrease-title-levels --start-title-level-at=2 docs_raw > README.md && node scripts/postProcessDocs.js",
    "lint": "eslint . --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "nuxt",
    "piwik-pro",
    "analytics",
    "plugin"
  ],
  "author": "Piwik Pro Integration Team <integrations@piwik.pro>",
  "license": "MIT",
  "dependencies": {
    "@piwikpro/vue-piwik-pro": "^1.7.0"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^0.3.13",
    "@types/node": "^20.10.7",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "auto-changelog": "^2.6.0",
    "concat-md": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.26.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.3.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  }
}
